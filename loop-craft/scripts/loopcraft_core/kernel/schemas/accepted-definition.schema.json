{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loopcraft.local/schemas/accepted-definition.schema.json",
  "title": "Loop Craft Accepted Definition",
  "$defs": {
    "nonBlankString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "behavior_contract", "loops"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "profile": {
      "enum": ["core-slice-v0.1", "skill-package-v0.1"]
    },
    "behavior_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "purpose", "applicability", "interface", "authority", "capabilities"],
      "properties": {
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "version", "description"],
          "properties": {
            "id": {
              "type": "string",
              "maxLength": 64,
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
              "not": {"pattern": "[\\u0000-\\u001F\\u007F-\\u009F]"}
            },
            "name": {"$ref": "#/$defs/nonBlankString"},
            "version": {
              "type": "string",
              "pattern": "^0\\.[0-9]+\\.[0-9]+$",
              "not": {"pattern": "[\\u0000-\\u001F\\u007F-\\u009F]"}
            },
            "description": {"$ref": "#/$defs/nonBlankString"}
          }
        },
        "purpose": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome"],
          "properties": {
            "outcome": {"$ref": "#/$defs/nonBlankString"}
          }
        },
        "applicability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["use_when", "do_not_use_when"],
          "properties": {
            "use_when": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/nonBlankString"}
            },
            "do_not_use_when": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"}
            }
          }
        },
        "interface": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputs", "outputs"],
          "properties": {
            "inputs": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            },
            "outputs": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            }
          }
        },
        "authority": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed", "approval_required", "forbidden"],
          "properties": {
            "allowed": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            },
            "approval_required": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            },
            "forbidden": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            }
          }
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "optional"],
          "properties": {
            "required": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            },
            "optional": {
              "type": "array",
              "items": {"$ref": "#/$defs/nonBlankString"},
              "uniqueItems": true
            }
          }
        },
        "workflow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["steps", "success_evidence", "failure_or_stop"],
          "properties": {
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/nonBlankString"}
            },
            "success_evidence": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/nonBlankString"}
            },
            "failure_or_stop": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/nonBlankString"}
            }
          }
        }
      }
    },
    "loops": {
      "type": "array",
      "minItems": 0,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "cycle", "terminal_states", "invariants"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "not": {"pattern": "[\\u0000-\\u001F\\u007F-\\u009F]"}
          },
          "cycle": {
            "type": "object",
            "additionalProperties": false,
            "required": ["observe", "choose", "act", "verify", "record", "adapt"],
            "properties": {
              "observe": {"$ref": "#/$defs/nonBlankString"},
              "choose": {"$ref": "#/$defs/nonBlankString"},
              "act": {"$ref": "#/$defs/nonBlankString"},
              "verify": {"$ref": "#/$defs/nonBlankString"},
              "record": {"$ref": "#/$defs/nonBlankString"},
              "adapt": {"$ref": "#/$defs/nonBlankString"}
            }
          },
          "terminal_states": {
            "type": "object",
            "additionalProperties": false,
            "required": ["success", "clean_no_op", "blocked", "stagnated", "exhausted"],
            "properties": {
              "success": {"$ref": "#/$defs/nonBlankString"},
              "clean_no_op": {"$ref": "#/$defs/nonBlankString"},
              "blocked": {"$ref": "#/$defs/nonBlankString"},
              "stagnated": {"$ref": "#/$defs/nonBlankString"},
              "exhausted": {"$ref": "#/$defs/nonBlankString"}
            }
          },
          "invariants": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/nonBlankString"}
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"profile": {"const": "core-slice-v0.1"}},
        "required": ["profile"]
      },
      "then": {
        "properties": {
          "behavior_contract": {
            "properties": {"workflow": false}
          },
          "loops": {"minItems": 1, "maxItems": 1}
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {"const": "skill-package-v0.1"},
          "loops": {"maxItems": 0}
        },
        "required": ["profile", "loops"]
      },
      "then": {
        "properties": {
          "behavior_contract": {"required": ["workflow"]}
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile": {"const": "skill-package-v0.1"},
          "loops": {"minItems": 1}
        },
        "required": ["profile", "loops"]
      },
      "then": {
        "properties": {
          "behavior_contract": {
            "properties": {"workflow": false}
          }
        }
      }
    }
  ]
}
